generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model Tenants {
  id            String   @id @default(uuid())
  cursor        Int      @default(autoincrement()) @unique
  title         String
  email         String   @unique
  phone         String   @unique
  password      String
  role          Role     @default(COMPANIE)
  isActive      Boolean  @default(true)
  isVerified    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  totalErned Decimal        @db.Decimal(12,2) @default(0)
  totalDisponible Decimal        @db.Decimal(12,2)  @default(0)
  totalErnedWithTax Decimal        @db.Decimal(12,2)  @default(0)

  keys          ApiSecretKeys[]
  kycValidation KycValidation?
  notifications Notification[]
  transactions  Transaction[]
  wallet        Wallet?
  withdrawals   Withdrawals[]

  @@index([email])
  @@index([phone])
  @@index([isActive])
}

model KycValidation {
  id                 String               @id @default(uuid())
  companieId         String               @unique
  documentFrontUrl   String
  documentBackUrl    String
  bi                 String               @unique
  status             VerificationStatus   @default(PENDING)
  notes              String?
  verified           Boolean              @default(false)
  verifiedAt         DateTime?
  expiredAt          DateTime
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  companie           Tenants               @relation(fields: [companieId], references: [id], onDelete: Cascade)
}

model ApiSecretKeys {
  id         String   @id @default(uuid())
  title      String
  companieId String
  publicKey  String  @unique
  secretKey  String
  isActive   Boolean @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  companie   Tenants @relation(fields: [companieId], references: [id], onDelete: Cascade)

  @@index([companieId])
  @@index([isActive])
}

model Transaction {
  id           String        @id @default(uuid())
  companieId   String
  externId String
  getawayIdentifier String
  status       PaymentStatus @default(PENDING)

  amount       Decimal       @db.Decimal(12,2)
  subtotal     Decimal       @db.Decimal(12,2)
  tax          Decimal       @db.Decimal(12,2)
  total        Decimal       @db.Decimal(12,2)

  taxType      TaxType       @default(PERCENT)
  method       PaymentMethod @default(REFERENCE)
  currency     String        @default("AOA")

  signature    String
  entity       String?
  reference    String?       @unique
  qrCodeUrl    String?
  paymentUrl   String?
  callbackUrl  String

  paidAt       DateTime?
  failureReason String?

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  companie     Tenants       @relation(fields: [companieId], references: [id], onDelete: Cascade)
  client       TransactionClientInfo?
  items        TransactionItem[]
  webhooksDelivery WebhookDelivery[]

  @@index([companieId])
  @@index([status])
  @@index([createdAt])
}

model TransactionItem {
  id            String   @id @default(uuid())
  transactionId String
  title         String
  price         Decimal  @db.Decimal(12,2)
  quantity      Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
}

model TransactionClientInfo {
  id            String   @id @default(uuid())
  transactionId String   @unique
  name          String
  email         String
  phone         String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}



model WebhookDelivery {
  id             String   @id @default(uuid())
  transactionId  String
  event          WebHooksEvents
  url            String
  payload        Json
  status         WebhookDeliveryStatus @default(PENDING)
  attempts       Int      @default(0)
  lastError      String?
  deliveredAt    DateTime?
  nextRetryAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  transaction    Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  @@unique([transactionId, event])
  @@index([status])
}


model Wallet {
  id           String   @id @default(uuid())
  companieId   String   @unique
  walletHolder String
  iban         String
  bank         String
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  companie     Tenants        @relation(fields: [companieId], references: [id], onDelete: Cascade)
  withdrawals  Withdrawals[]
}

model Withdrawals {
  id                 String        @id @default(uuid())
  walletId           String
  companieId         String
  amount             Decimal       @db.Decimal(12,2)
  status             PaymentStatus  @default(PENDING)
  fileUrl            String?
  notes              String?
  approvedAt         DateTime?
  revokedAt          DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  companie            Tenants       @relation(fields: [companieId], references: [id], onDelete: Cascade)
  wallet              Wallet        @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([companieId])
  @@index([walletId])
  @@index([status])
}


model Notification {
  id         String           @id @default(uuid())
  entitieId String  @unique
  companieId String
  message    String
  type       NotificationType
  isRead     Boolean          @default(false)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  companie   Tenants          @relation(fields: [companieId], references: [id], onDelete: Cascade)

  @@index([companieId])
  @@index([isRead])
  
}

enum Role {
  COMPANIE
  SUPERCOMPANIE
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum PaymentStatus {
  PAID
  PENDING
  FAILED
  APPROVED
  REJECTED
}

enum PaymentMethod {
  REFERENCE
}

enum WebhooksScope {
  PAYMENTS
  WITHDRAWALS
}

enum WebHooksEvents {
  SUCCESS
  ERROR
  CREATED
  REJECTED
}

enum NotificationType {
  PAYMENT
  WITHDRAWALS
  SECURITY
  OTHERS
}

enum WebHooksMethod {
  GET
  POST
  PUT
  PATCH
}

enum TaxType {
  PERCENT
  FIXED
  IVA
  NONE
}

enum WebhookDeliveryStatus {
  PENDING
  SUCCESS
  FAILED
}
